{
  "textCorrection": {
    "replacements": [
      {
        "pattern": "\\.{3}",
        "replacement": "……"
      },
      {
        "pattern": "->",
        "replacement": "→"
      },
      {
        "pattern": "(?<=\\d)x(?=\\d)",
        "replacement": "×"
      }
    ]
  },
  "other": {
    "spacingLineBeforeCustomEnding": 8,
    "customEnding": "---End---"
  }
}
