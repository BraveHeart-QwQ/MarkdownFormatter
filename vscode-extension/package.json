{
  "name": "markdown-formatter",
  "displayName": "Markdown Formatter",
  "description": "Format Markdown files with CJK-aware word-spacing, list, table, and heading rules",
  "version": "1.0.2",
  "publisher": "BraveHeart",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownFormatter.formatDocument",
        "title": "Markdown Formatter: Format Document"
      },
      {
        "command": "markdownFormatter.formatDocumentWithProfile",
        "title": "Markdown Formatter: Format Document with Profile"
      },
      {
        "command": "markdownFormatter.formatSelectionWithProfile",
        "title": "Markdown Formatter: Format Selection with Profile"
      },
      {
        "command": "markdownFormatter.profile.clearInlineCodeAndMath.selection",
        "title": "Markdown Formatter: Clear Inline Code and Math (Selection)"
      },
      {
        "command": "markdownFormatter.profile.clearInlineStrongCodeAndMath.selection",
        "title": "Markdown Formatter: Clear Inline Strong, Code and Math (Selection)"
      },
      {
        "command": "markdownFormatter.profile.clearInlineStrong.selection",
        "title": "Markdown Formatter: Clear Inline Strong (Selection)"
      },
      {
        "command": "markdownFormatter.profile.clearInlineCode.selection",
        "title": "Markdown Formatter: Clear Inline Code (Selection)"
      },
      {
        "command": "markdownFormatter.profile.clearInlineMath.selection",
        "title": "Markdown Formatter: Clear Inline Math (Selection)"
      },
      {
        "command": "markdownFormatter.profile.formatInlineToCode.selection",
        "title": "Markdown Formatter: Format Inline to Code (Selection)"
      },
      {
        "command": "markdownFormatter.profile.formatInlineToMath.selection",
        "title": "Markdown Formatter: Format Inline to Math (Selection)"
      }
    ],
    "configuration": {
      "title": "Markdown Formatter",
      "properties": {
        "markdownFormatter.baseConfig": {
          "type": "object",
          "default": {},
          "markdownDescription": "全局基础配置对象，结构与 `#markdownFormatter.config#` 相同，但叠加顺序更靠前（在 `#markdownFormatter.configFiles#` 之前）。适合在用户设置中存放全局通用配置，由项目的 `config` 或 `configFiles` 覆盖。",
          "properties": {
            "textCorrection": {
              "type": "object"
            },
            "blockIndent": {
              "type": "object"
            },
            "lineSpacing": {
              "type": "object"
            },
            "wordSpacing": {
              "type": "object"
            },
            "list": {
              "type": "object"
            },
            "table": {
              "type": "object"
            },
            "inline": {
              "type": "object"
            },
            "other": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        "markdownFormatter.configFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Base config JSON file paths (workspace-root-relative or absolute) applied on every format. Equivalent to `-c` in the CLI."
        },
        "markdownFormatter.profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Path to a config JSON file (workspace-root-relative or absolute)."
                },
                {
                  "type": "object",
                  "description": "Inline partial config object, same structure as a config JSON file.",
                  "properties": {
                    "textCorrection": {
                      "type": "object"
                    },
                    "blockIndent": {
                      "type": "object"
                    },
                    "lineSpacing": {
                      "type": "object"
                    },
                    "wordSpacing": {
                      "type": "object"
                    },
                    "list": {
                      "type": "object"
                    },
                    "table": {
                      "type": "object"
                    },
                    "inline": {
                      "type": "object"
                    },
                    "other": {
                      "type": "object"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          },
          "default": {},
          "markdownDescription": "Named config profiles. Each key is a profile name; the value is an ordered list of entries merged **after** `#markdownFormatter.configFiles#`. Each entry can be a file path string or an inline partial config object. Select a profile via the *Format Document/Selection with Profile* commands.\n\nExample:\n```json\n{\n  \"compact\": [\n    \"base.json\",\n    { \"lineSpacing\": { \"blankLinesBeforeH2\": 1 } }\n  ]\n}\n```"
        },
        "markdownFormatter.config": {
          "type": "object",
          "default": {},
          "markdownDescription": "Inline formatter config object. Merged **after** `#markdownFormatter.configFiles#`, so these values take highest priority. Uses the same structure as a config JSON file. Example:\n```json\n{\n  \"wordSpacing\": { \"spaceBetweenChineseAndEnglish\": false },\n  \"lineSpacing\": { \"blankLinesBeforeH2\": 2 }\n}\n```",
          "properties": {
            "textCorrection": {
              "type": "object"
            },
            "blockIndent": {
              "type": "object"
            },
            "lineSpacing": {
              "type": "object"
            },
            "wordSpacing": {
              "type": "object"
            },
            "list": {
              "type": "object"
            },
            "table": {
              "type": "object"
            },
            "inline": {
              "type": "object"
            },
            "other": {
              "type": "object"
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
